# PaperBook Monorepo Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/paperbook

# =============================================================================
# Server
# =============================================================================
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# =============================================================================
# Auth (Legacy JWT — still supported for backward compatibility)
# =============================================================================
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# better-auth
# =============================================================================
BETTER_AUTH_SECRET=your-better-auth-secret-here
BETTER_AUTH_URL=http://localhost:3001

# =============================================================================
# Google OAuth (optional)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# AI / LLM (optional)
# =============================================================================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Frontend (School App) — prefix with VITE_
# =============================================================================
VITE_API_URL=http://localhost:3001
VITE_USE_MOCK_API=true
VITE_ENABLE_MSW=true
VITE_SESSION_TIMEOUT_MS=1800000
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development
