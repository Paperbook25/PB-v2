# =============================================================================
# Paperbook — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# --- Database ---
POSTGRES_USER=paperbook
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=paperbook

# --- Auth Secrets (min 32 chars each in production) ---
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- URLs ---
BETTER_AUTH_URL=https://paperbook.app
CORS_ORIGIN=https://paperbook.app,https://admin.paperbook.app,https://gravity.paperbook.app
APP_DOMAIN=paperbook.app

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- SMTP / Email (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@paperbook.app

# --- AI / LLM (optional) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b
