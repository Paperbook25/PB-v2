{
  "expo": {
    "name": "PaperBook",
    "slug": "paperbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.paperbook.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366f1"
      },
      "package": "app.paperbook.mobile"
    },
    "scheme": "paperbook",
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
