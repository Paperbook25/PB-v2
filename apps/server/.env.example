# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/paperbook"

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# AI / LLM — Local AI via Ollama (default)
LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:14b"

# Optional: cloud LLM providers (leave empty to use Ollama)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Email — Resend (https://resend.com)
# Get your API key from: https://resend.com/api-keys
# Set EMAIL_FROM to a verified domain address, e.g. "PaperBook <noreply@yourdomain.com>"
# Until you verify a domain, you can use: "PaperBook <onboarding@resend.dev>" (Resend test address)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="PaperBook <noreply@paperbook.app>"

# Platform domain (used in email links)
APP_DOMAIN="paperbook.app"
BETTER_AUTH_URL="https://app.paperbook.app"
