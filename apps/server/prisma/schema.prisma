  substituteSubstitutions Substitution[]                 @relation("SubstituteTeacher")

  @@unique([organizationId, email])
  @@unique([organizationId, employeeId])
  @@index([departmentId])
  @@index([designationId])
  @@index([status])
  @@index([employeeId])
  @@index([organizationId])
  @@map("staff")
}

model StaffAddress {
