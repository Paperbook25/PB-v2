generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// better-auth tables (auto-managed by better-auth)
// ============================================================================

model BetterAuthUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  role          String?   @default("user") // "user" or "admin" (super admin)
  banned        Boolean?  @default(false)
  banReason     String?   @map("ban_reason")
  banExpires    DateTime? @map("ban_expires")

  sessions    BetterAuthSession[]
  accounts    BetterAuthAccount[]
  members     OrgMember[]
  invitations OrgInvitation[]

  @@map("better_auth_user")
}

model BetterAuthSession {
  id                   String   @id
  expiresAt            DateTime @map("expires_at")
  token                String   @unique
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  userId               String   @map("user_id")
  activeOrganizationId String?  @map("active_organization_id")
  impersonatedBy       String?  @map("impersonated_by")

  user BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("better_auth_session")
}

model BetterAuthAccount {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("better_auth_account")
}

model BetterAuthVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("better_auth_verification")
}

// ============================================================================
// better-auth Organization tables (school = organization)
// ============================================================================

model Organization {
  id        String   @id
  name      String
  slug      String?  @unique
  logo      String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  members     OrgMember[]
  invitations OrgInvitation[]
  profile     SchoolProfile?

  @@map("organization")
}

model OrgMember {
  id             String   @id
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           String   @default("member") // owner, admin, member
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("org_member")
}

model OrgInvitation {
  id             String   @id
  organizationId String   @map("organization_id")
  email          String
  role           String?
  status         String   @default("pending") // pending, accepted, rejected, canceled
  expiresAt      DateTime @map("expires_at")
  inviterId      String   @map("inviter_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      BetterAuthUser @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("org_invitation")
}

// ============================================================================
// Phase 1: Auth + Users (legacy — kept for backward compatibility)
// ============================================================================

enum Role {
  admin
  principal
  teacher
  accountant
  librarian
  transport_manager
  student
  parent
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Student-specific fields
  studentId  String? @map("student_id")
  class      String?
  section    String?
  rollNumber Int?    @map("roll_number")

  // Parent-specific fields
  childIds String? @map("child_ids") // JSON array stored as string

  sessions       Session[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]
  taughtSections Section[]       @relation("SectionClassTeacher")
  staff          Staff?

  @@index([role])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token") @db.VarChar(500)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  userName    String   @map("user_name")
  userRole    String   @map("user_role")
  action      String // create, update, delete, login, logout, export, import, status_change
  module      String // students, staff, admissions, attendance, finance, library, exams, transport, settings, auth, admin
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  entityName  String   @default("") @map("entity_name")
  description String   @db.Text
  changes     Json? // JSON array of { field, oldValue, newValue }
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  schoolId    String?  @map("school_id") // for tenant scoping
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([schoolId])
  @@map("audit_logs")
}

// ============================================================================
// Phase 2: School Settings + Academic Structure
// ============================================================================

enum AffiliationBoard {
  CBSE
  ICSE
  State
  IB
  Other
}

enum AcademicYearStatus {
  active
  completed
  upcoming
}

enum CalendarEventType {
  holiday
  exam
  ptm
  sports
  cultural
  workshop
  vacation
  other
}

enum TemplateCategory {
  fee
  attendance
  exam
  admission
  general
  transport
}

enum SchoolStatus {
  active
  suspended
  trial
  churned
}

enum PlanTier {
  free
  starter
  professional
  enterprise
}

model SchoolProfile {
  id                String            @id // Same ID as organization.id
  name              String
  address           String?
  city              String?
  state             String?
  pincode           String?           @db.VarChar(10)
  phone             String?
  email             String?
  website           String?
  logo              String?           @db.Text
  principalName     String?           @map("principal_name")
  establishedYear   Int?              @map("established_year")
  affiliationNumber String?           @map("affiliation_number")
  affiliationBoard  AffiliationBoard? @map("affiliation_board")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Multi-tenant management fields
  status        SchoolStatus @default(active)
  planTier      PlanTier     @default(free) @map("plan_tier")
  maxUsers      Int          @default(100) @map("max_users")
  maxStudents   Int          @default(500) @map("max_students")
  trialEndsAt   DateTime?    @map("trial_ends_at")
  suspendedAt   DateTime?    @map("suspended_at")
  suspendReason String?      @map("suspend_reason")
  onboardedAt   DateTime?    @map("onboarded_at")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  onboardingStep      Int     @default(0)     @map("onboarding_step")
  notes         String?      @db.Text // internal admin notes

  // Link to better-auth organization
  organization Organization? @relation(fields: [id], references: [id])

  schoolAddons    SchoolAddon[]
  subscriptions   PlatformSubscription[]
  platformInvoices PlatformInvoice[]

  @@index([status])
  @@index([planTier])
  @@map("school_profiles")
}

model AcademicYear {
  id             String             @id @default(uuid())
  organizationId String?            @map("organization_id")
  name           String // e.g. "2024-25"
  startDate      DateTime           @map("start_date") @db.Date
  endDate        DateTime           @map("end_date") @db.Date
  isCurrent      Boolean            @default(false) @map("is_current")
  status         AcademicYearStatus @default(upcoming)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  classSubjects ClassSubject[]
  leaveBalances LeaveBalance[]
  timetables    Timetable[]

  @@index([isCurrent])
  @@index([status])
  @@index([organizationId])
  @@map("academic_years")
}

model Class {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String // e.g. "Class 1"
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  sections         Section[]
  classSubjects    ClassSubject[]
  students         Student[]
  dailyAttendance  StudentDailyAttendance[]
  periodAttendance PeriodAttendance[]
  timetables       Timetable[]

  @@index([sortOrder])
  @@index([organizationId])
  @@map("classes")
}

model Section {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String // e.g. "A", "B"
  classId        String   @map("class_id")
  classTeacherId String?  @map("class_teacher_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  class            Class                    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher     User?                    @relation("SectionClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students         Student[]
  dailyAttendance  StudentDailyAttendance[]
  periodAttendance PeriodAttendance[]
  timetables       Timetable[]

  @@unique([classId, name])
  @@index([classId])
  @@index([classTeacherId])
  @@index([organizationId])
  @@map("sections")
}

model Subject {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String
  code           String
  type           String   @default("theory") // theory, practical, both
  maxMarks       Int      @default(100) @map("max_marks")
  passingMarks   Int      @default(33) @map("passing_marks")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  classSubjects    ClassSubject[]
  periodAttendance PeriodAttendance[]
  timetableEntries TimetableEntry[]
  studentMarks     StudentMark[]
  examSlots        ExamSlot[]         @relation("ExamSlotSubject")

  @@unique([organizationId, code])
  @@index([code])
  @@index([organizationId])
  @@map("subjects")
}

model ClassSubject {
  id             String   @id @default(uuid())
  classId        String   @map("class_id")
  subjectId      String   @map("subject_id")
  academicYearId String   @map("academic_year_id")
  createdAt      DateTime @default(now()) @map("created_at")

  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId, academicYearId])
  @@index([classId])
  @@index([subjectId])
  @@index([academicYearId])
  @@map("class_subjects")
}

model CalendarEvent {
  id               String            @id @default(uuid())
  organizationId   String?           @map("organization_id")
  title            String
  description      String            @default("") @db.VarChar(2000)
  type             CalendarEventType
  startDate        DateTime          @map("start_date") @db.Date
  endDate          DateTime          @map("end_date") @db.Date
  isRecurring      Boolean           @default(false) @map("is_recurring")
  appliesToClasses Json?             @map("applies_to_classes") // JSON string array
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([type])
  @@index([startDate, endDate])
  @@index([organizationId])
  @@map("calendar_events")
}

model EmailTemplate {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  name           String
  subject        String
  body           String           @db.Text
  category       TemplateCategory
  variables      Json // JSON string array of variable names
  isActive       Boolean          @default(true) @map("is_active")
  lastModified   DateTime         @default(now()) @map("last_modified")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@index([organizationId])
  @@map("email_templates")
}

model NotificationPreference {
  id                   String   @id @default(uuid())
  organizationId       String?  @map("organization_id")
  emailNotifications   Boolean  @default(true) @map("email_notifications")
  smsNotifications     Boolean  @default(true) @map("sms_notifications")
  feeReminders         Boolean  @default(true) @map("fee_reminders")
  attendanceAlerts     Boolean  @default(true) @map("attendance_alerts")
  examResults          Boolean  @default(true) @map("exam_results")
  generalAnnouncements Boolean  @default(true) @map("general_announcements")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("notification_preferences")
}

model BackupConfig {
  id                  String    @id @default(uuid())
  organizationId      String?   @map("organization_id")
  autoBackup          Boolean   @default(true) @map("auto_backup")
  backupFrequency     String    @default("daily") @map("backup_frequency") // daily, weekly, monthly
  lastBackupAt        DateTime? @map("last_backup_at")
  backupRetentionDays Int       @default(30) @map("backup_retention_days")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("backup_configs")
}

model ThemeConfig {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  mode           String   @default("system") // light, dark, system
  primaryColor   String   @default("#6d28d9") @map("primary_color")
  accentColor    String   @default("#7c3aed") @map("accent_color")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("theme_configs")
}

