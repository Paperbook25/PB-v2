// ==================== Student Models ====================

model Student {
  id              String        @id @default(uuid())
  organizationId  String?       @map("organization_id")
  admissionNumber String        @map("admission_number")
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  email           String
  phone           String?
  dateOfBirth     DateTime?     @map("date_of_birth") @db.Date
  gender          Gender?
  bloodGroup      String?       @map("blood_group")
  classId         String        @map("class_id")
  sectionId       String        @map("section_id")
  rollNumber      Int?          @map("roll_number")
  admissionDate   DateTime?     @map("admission_date") @db.Date
  photoUrl        String?       @map("photo_url")
  status          StudentStatus @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  class               Class                     @relation(fields: [classId], references: [id])
  section             Section                   @relation(fields: [sectionId], references: [id])
  address             StudentAddress?
  parent              StudentParent?
  healthRecord        StudentHealthRecord?
  documents           StudentDocument[]
  timelineEvents      StudentTimelineEvent[]
  skills              StudentSkill[]
  portfolioItems      StudentPortfolioItem[]
  siblingsOf          StudentSibling[]          @relation("SiblingStudent")
  siblingsWith        StudentSibling[]          @relation("SiblingOfStudent")
  attendanceRecords   StudentAttendanceRecord[]
  studentFees         StudentFee[]
  feePayments         Payment[]
  marks               StudentMark[]
  reportCards         ReportCard[]
  coScholasticRecords CoScholasticRecord[]
  attendanceAlerts    AttendanceAlert[]

  @@unique([organizationId, email])
  @@unique([organizationId, admissionNumber])
  @@index([classId])
  @@index([sectionId])
  @@index([status])
  @@index([admissionNumber])
  @@index([organizationId])
  @@map("students")
}

model StudentAddress {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  studentId      String   @unique @map("student_id")
  street         String?
  city           String?
  state          String?
  pincode        String?  @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("student_addresses")
}

model StudentParent {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  studentId      String   @unique @map("student_id")
  fatherName     String?  @map("father_name")
  motherName     String?  @map("mother_name")
  guardianPhone  String?  @map("guardian_phone")
  guardianEmail  String?  @map("guardian_email")
  occupation     String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("student_parents")
}

model StudentHealthRecord {
  id                String    @id @default(uuid())
  organizationId    String?   @map("organization_id")
  studentId         String    @unique @map("student_id")
  allergies         Json?
  medicalConditions Json?     @map("medical_conditions")
  medications       Json?
  emergencyContact  Json?     @map("emergency_contact")
  bloodGroup        String?   @map("blood_group")
  height            Float?
  weight            Float?
  visionLeft        String?   @map("vision_left")
  visionRight       String?   @map("vision_right")
  lastCheckupDate   DateTime? @map("last_checkup_date") @db.Date
  insuranceProvider String?   @map("insurance_provider")
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("student_health_records")
}

model StudentDocument {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  studentId      String       @map("student_id")
  type           DocumentType
  name           String
  fileName       String       @map("file_name")
  fileSize       Int?         @map("file_size")
  mimeType       String?      @map("mime_type")
  url            String
  uploadedBy     String?      @map("uploaded_by")
  verified       Boolean      @default(false)
  verifiedBy     String?      @map("verified_by")
  verifiedAt     DateTime?    @map("verified_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([organizationId])
  @@map("student_documents")
}

model StudentTimelineEvent {
  id             String            @id @default(uuid())
  organizationId String?           @map("organization_id")
  studentId      String            @map("student_id")
  type           TimelineEventType
  title          String
  description    String?           @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([createdAt])
  @@index([organizationId])
  @@map("student_timeline_events")
}

model StudentSibling {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  studentId      String   @map("student_id")
  siblingId      String   @map("sibling_id")
  createdAt      DateTime @default(now()) @map("created_at")

  student Student @relation("SiblingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  sibling Student @relation("SiblingOfStudent", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([studentId])
  @@index([siblingId])
  @@index([organizationId])
  @@map("student_siblings")
}

model StudentSkill {
  id               String        @id @default(uuid())
  studentId        String        @map("student_id")
  name             String
  category         SkillCategory
