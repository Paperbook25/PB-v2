// ============================================================================
// Scholarships
// ============================================================================

model Scholarship {
  id                String   @id @default(uuid())
  organizationId    String?  @map("organization_id")
  name              String
  description       String?  @db.Text
  type              String   @default("merit") // merit, need_based, sports, cultural, minority, sibling
  amount            Decimal  @db.Decimal(10, 2)
  percentage        Int?     // discount percentage (alternative to fixed amount)
  eligibility       String?  @db.Text
  maxRecipients     Int?     @map("max_recipients")
  currentRecipients Int      @default(0) @map("current_recipients")
  academicYear      String?  @map("academic_year")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  recipients ScholarshipRecipient[]

  @@index([organizationId])
  @@index([type])
  @@map("scholarships")
}

model ScholarshipRecipient {
  id            String    @id @default(uuid())
  scholarshipId String    @map("scholarship_id")
  studentId     String    @map("student_id")
  studentName   String    @map("student_name")
  className     String?   @map("class_name")
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("active") // active, revoked, completed
  awardedDate   DateTime  @default(now()) @map("awarded_date") @db.Date
  revokedDate   DateTime? @map("revoked_date") @db.Date
  revokeReason  String?   @map("revoke_reason") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id])

  @@index([scholarshipId])
  @@index([studentId])
  @@map("scholarship_recipients")
}

