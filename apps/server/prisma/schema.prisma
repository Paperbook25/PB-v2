// ============================================================================
// Clubs & Activities
// ============================================================================

model Club {
  id              String   @id @default(uuid())
  organizationId  String?  @map("organization_id")
  name            String
  description     String?  @db.Text
  category        String   @default("academic") // academic, sports, cultural, community, technology
  coordinatorId   String?  @map("coordinator_id")
  coordinatorName String?  @map("coordinator_name")
  meetingDay      String?  @map("meeting_day")
  meetingTime     String?  @map("meeting_time")
  location        String?
  maxMembers      Int?     @map("max_members")
