  @@index([organizationId])
  @@index([formType])
  @@index([sessionId])
  @@index([timestamp])
  @@map("form_analytics")
}

// ============================================================================
// Email Campaign / Drip System
// ============================================================================

model EmailCampaign {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String
  description    String?  @db.Text
  trigger        String   @default("manual") // manual, admission_inquiry, contact_form, fee_overdue, event_registration
  status         String   @default("draft")  // draft, active, paused, completed
  targetAudience String   @default("all")    @map("target_audience") // all, parents, students, staff, leads
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  steps EmailCampaignStep[]
  logs  EmailCampaignLog[]

  @@index([organizationId])
  @@index([status])
  @@map("email_campaigns")
}

model EmailCampaignStep {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  sortOrder  Int      @default(0) @map("sort_order")
  delayDays  Int      @default(0) @map("delay_days")
  subject    String
  body       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("email_campaign_steps")
}

model EmailCampaignLog {
  id             String    @id @default(uuid())
  campaignId     String    @map("campaign_id")
  stepId         String?   @map("step_id")
  recipientEmail String    @map("recipient_email")
  recipientName  String?   @map("recipient_name")
  status         String    @default("pending") // pending, sent, failed, opened, clicked
  sentAt         DateTime? @map("sent_at")
  openedAt       DateTime? @map("opened_at")
  error          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@map("email_campaign_logs")
}

// ============================================================================
// Gravity Portal — Platform Subscription & Billing
// ============================================================================

enum BillingCycle {
  monthly
  quarterly
  semi_annual
  annual
}

enum SubscriptionStatus {
  sub_active
  sub_trial
  sub_past_due
  sub_cancelled
  sub_expired
}

enum InvoiceStatus {
  inv_draft
  inv_sent
  inv_paid
  inv_overdue
  inv_cancelled
  inv_refunded
}

enum PlatformPaymentMethod {
  bank_transfer
  upi
  card
  cash
  cheque
  other
}

model PlatformSubscription {
  id                 String             @id @default(uuid())
  schoolId           String             @map("school_id")
  planTier           PlanTier           @map("plan_tier")
  status             SubscriptionStatus @default(sub_trial)
  billingCycle       BillingCycle       @default(monthly) @map("billing_cycle")
  amount             Decimal            @db.Decimal(12, 2)
  currency           String             @default("INR") @db.VarChar(3)
  trialStartedAt     DateTime?          @map("trial_started_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  cancelReason       String?            @map("cancel_reason")
  nextBillingDate    DateTime?          @map("next_billing_date")
  notes              String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  school   SchoolProfile     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoices PlatformInvoice[]

  @@index([schoolId])
  @@index([status])
  @@index([planTier])
  @@index([nextBillingDate])
  @@map("platform_subscriptions")
}

model PlatformInvoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique @map("invoice_number")
  subscriptionId     String?       @map("subscription_id")
  schoolId           String        @map("school_id")
  status             InvoiceStatus @default(inv_draft)
  subtotal           Decimal       @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @db.Decimal(12, 2) @map("tax_amount")
  taxRate            Decimal       @default(0) @db.Decimal(5, 2) @map("tax_rate")
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2) @map("total_amount")
  currency           String        @default("INR") @db.VarChar(3)
  dueDate            DateTime      @map("due_date")
  paidAt             DateTime?     @map("paid_at")
  notes              String?       @db.Text
  lineItems          Json?         @map("line_items")
  billingPeriodStart DateTime?     @map("billing_period_start")
  billingPeriodEnd   DateTime?     @map("billing_period_end")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  subscription PlatformSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  school       SchoolProfile         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments     PlatformPayment[]

  @@index([schoolId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@map("platform_invoices")
}

model PlatformPayment {
  id             String                @id @default(uuid())
  invoiceId      String                @map("invoice_id")
  amount         Decimal               @db.Decimal(12, 2)
  paymentMethod  PlatformPaymentMethod @map("payment_method")
  transactionRef String?               @map("transaction_ref")
  paidAt         DateTime              @default(now()) @map("paid_at")
  notes          String?               @db.Text
  recordedBy     String?               @map("recorded_by")
  createdAt      DateTime              @default(now()) @map("created_at")

  invoice PlatformInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("platform_payments")
}

// ============================================================================
// Gravity Portal — CRM (Lead Management)
// ============================================================================

enum LeadStatus {
  lead_new
  lead_contacted
  lead_qualified
  lead_demo
  lead_proposal
  lead_negotiation
  lead_won
  lead_lost
}

enum LeadSource {
  website
  referral
  social_media
  cold_call
  event
  partner
  other
}

model Lead {
  id              String     @id @default(uuid())
  schoolName      String     @map("school_name")
  contactName     String     @map("contact_name")
  contactEmail    String     @map("contact_email")
  contactPhone    String?    @map("contact_phone")
  city            String?
  state           String?
  status          LeadStatus @default(lead_new)
  source          LeadSource @default(website)
  expectedRevenue Decimal?   @db.Decimal(12, 2) @map("expected_revenue")
  expectedPlan    PlanTier?  @map("expected_plan")
  assignedTo      String?    @map("assigned_to")
  notes           String?    @db.Text
  lostReason      String?    @map("lost_reason")
  convertedSchoolId String?  @map("converted_school_id")
  nextFollowUp    DateTime?  @map("next_follow_up")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  activities LeadActivity[]

  @@index([status])
  @@index([source])
  @@index([assignedTo])
  @@index([nextFollowUp])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  type      String   // email, call, meeting, note, status_change, demo
  content   String   @db.Text
  createdBy String?  @map("created_by")
  metadata  Json?    // optional structured data (e.g., old/new status for status_change)
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
  @@map("lead_activities")
}

// ============================================================================
// Gravity Portal — Platform Announcements
// ============================================================================

enum AnnouncementStatus {
  ann_draft
  ann_scheduled
  ann_sent
}

enum AnnouncementChannel {
  in_app
  email
  both
}

model PlatformAnnouncement {
  id          String              @id @default(uuid())
  title       String
  body        String              @db.Text
  channel     AnnouncementChannel @default(in_app)
  status      AnnouncementStatus  @default(ann_draft)
  targetPlans PlanTier[]          @map("target_plans")
  targetStatuses String[]         @map("target_statuses") // school statuses: active, trial, etc.
  scheduledAt DateTime?           @map("scheduled_at")
  sentAt      DateTime?           @map("sent_at")
  createdBy   String?             @map("created_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@index([scheduledAt])
  @@map("platform_announcements")
}

// ============================================================================
// Gravity Portal — Usage Tracking
// ============================================================================

model UsageMetric {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  metricType String   @map("metric_type") // api_calls, storage_mb, active_users, logins
  value      Decimal  @db.Decimal(12, 2)
  period     String   // daily, monthly
  recordedAt DateTime @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([schoolId, metricType, recordedAt])
  @@index([recordedAt])
  @@map("usage_metrics")
}

// ============================================================================
// Gravity Portal — System Health
// ============================================================================

model SystemAlert {
  id           String    @id @default(uuid())
  type         String    // error_rate, response_time, uptime, disk_space, maintenance
  severity     String    // info, warning, critical
  message      String
  threshold    Decimal?  @db.Decimal(10, 2)
  currentValue Decimal?  @db.Decimal(10, 2) @map("current_value")
  isResolved   Boolean   @default(false) @map("is_resolved")
  resolvedAt   DateTime? @map("resolved_at")
  resolvedBy   String?   @map("resolved_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([type, isResolved])
  @@map("system_alerts")
}

model HealthMetric {
  id         String   @id @default(uuid())
  metricType String   @map("metric_type") // response_time_ms, error_count, request_count, memory_mb, cpu_percent
  value      Decimal  @db.Decimal(10, 2)
  recordedAt DateTime @map("recorded_at")

  @@index([metricType, recordedAt])
  @@map("health_metrics")
}

// ============================================================================
// Gravity Portal — Multi-Admin Roles
// ============================================================================

model GravityAdmin {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  role        String    @default("admin") // super_admin, admin, viewer, billing_admin, support
  permissions Json?     // Array of permission slugs
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("gravity_admins")
}
