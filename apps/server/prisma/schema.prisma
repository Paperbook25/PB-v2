model AdmissionApplication {
  id                String          @id @default(uuid())
  organizationId    String?         @map("organization_id")
  applicationNumber String          @unique @map("application_number")
  status            AdmissionStatus @default(adm_applied)

  studentName String   @map("student_name")
  dateOfBirth DateTime @map("date_of_birth") @db.Date
  gender      Gender
  photoUrl    String?  @map("photo_url")

  email          String
  phone          String
  addressStreet  String? @map("address_street")
  addressCity    String? @map("address_city")
  addressState   String? @map("address_state")
  addressPincode String? @map("address_pincode") @db.VarChar(10)

  applyingForClass   String  @map("applying_for_class")
  applyingForSection String? @map("applying_for_section")
  previousSchool     String  @map("previous_school")
  previousClass      String  @map("previous_class")
  previousMarks      Float   @map("previous_marks")

  fatherName         String  @map("father_name")
  motherName         String  @map("mother_name")
  guardianPhone      String  @map("guardian_phone")
  guardianEmail      String  @map("guardian_email")
  guardianOccupation String? @map("guardian_occupation")

  entranceExamDate  DateTime? @map("entrance_exam_date") @db.Date
  entranceExamScore Float?    @map("entrance_exam_score")
  interviewDate     DateTime? @map("interview_date") @db.Date
  interviewScore    Float?    @map("interview_score")
  interviewNotes    String?   @map("interview_notes") @db.Text

  source            AdmissionSource? @default(asrc_walk_in)
  referredBy        String?          @map("referred_by")
  enrolledStudentId String?          @map("enrolled_student_id")
  waitlistPosition  Int?             @map("waitlist_position")

  admissionFeeStatus AdmFeeStatus? @map("admission_fee_status")
  admissionFeeAmount Decimal?      @map("admission_fee_amount") @db.Decimal(12, 2)
  admissionFeePaid   Decimal?      @map("admission_fee_paid") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  documents      AdmissionDocument[]
  statusHistory  AdmissionStatusHistory[]
  notes          AdmissionNote[]
  payments       AdmissionPayment[]
  communications AdmissionCommunication[]

  @@index([status])
  @@index([applyingForClass])
  @@index([createdAt])
  @@index([applicationNumber])
  @@index([organizationId])
  @@map("admission_applications")
}

model AdmissionDocument {
  id              String            @id @default(uuid())
  organizationId  String?           @map("organization_id")
  applicationId   String            @map("application_id")
  type            AdmDocumentType
  name            String
  url             String
  status          AdmDocumentStatus @default(ads_pending)
  verifiedBy      String?           @map("verified_by")
  verifiedAt      DateTime?         @map("verified_at")
  rejectionReason String?           @map("rejection_reason") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([organizationId])
  @@map("admission_documents")
}

model AdmissionStatusHistory {
  id            String           @id @default(uuid())
  applicationId String           @map("application_id")
  fromStatus    AdmissionStatus? @map("from_status")
  toStatus      AdmissionStatus  @map("to_status")
  changedBy     String           @map("changed_by")
  note          String?          @db.Text
  changedAt     DateTime         @default(now()) @map("changed_at")

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("admission_status_history")
}

model AdmissionNote {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  content       String   @db.Text
  createdBy     String   @map("created_by")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("admission_notes")
}

model AdmEntranceExamSchedule {
  id              String                @id @default(uuid())
  class           String
  examDate        DateTime              @map("exam_date") @db.Date
  examTime        String                @map("exam_time") @db.VarChar(10)
  venue           String
  duration        Int
  totalMarks      Int                   @map("total_marks")
  passingMarks    Int                   @map("passing_marks")
  subjects        Json
  registeredCount Int                   @default(0) @map("registered_count")
  completedCount  Int                   @default(0) @map("completed_count")
  status          AdmExamScheduleStatus @default(aes_upcoming)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  @@index([class])
  @@index([status])
  @@map("adm_entrance_exam_schedules")
}

model AdmissionPayment {
  id            String       @id @default(uuid())
  applicationId String       @map("application_id")
  totalAmount   Decimal      @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal      @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status        AdmFeeStatus @default(afs_pending)
  paymentDate   DateTime?    @map("payment_date") @db.Date
  paymentMethod String?      @map("payment_method")
  transactionId String?      @map("transaction_id")
  receiptNumber String?      @map("receipt_number")
  feeBreakdown  Json?        @map("fee_breakdown")
  dueDate       DateTime     @map("due_date") @db.Date
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@map("admission_payments")
}

model AdmissionCommunication {
  id            String             @id @default(uuid())
  applicationId String             @map("application_id")
  type          CommType
  trigger       CommTrigger
  recipient     String
  subject       String
  message       String             @db.Text
  status        CommDeliveryStatus @default(cds_pending)
  sentBy        String             @map("sent_by")
  sentAt        DateTime           @default(now()) @map("sent_at")

  application AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([type])
  @@map("admission_communications")
}

model AdmissionCommTemplate {
  id        String      @id @default(uuid())
  name      String
  trigger   CommTrigger
  type      CommType
  subject   String
  body      String      @db.Text
  isActive  Boolean     @default(true) @map("is_active")
  variables Json
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("admission_comm_templates")
}

