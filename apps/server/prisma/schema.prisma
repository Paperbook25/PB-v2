// ============================================================================
// Facilities
// ============================================================================

model Facility {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String
  type           String   @default("general") // classroom, lab, library, sports, auditorium, cafeteria, medical, other
  description    String?  @db.Text
  location       String?
  capacity       Int?
  isBookable     Boolean  @default(false) @map("is_bookable")
  status         String   @default("available") // available, occupied, maintenance, closed
  imageUrl       String?  @map("image_url") @db.Text
  amenities      Json?    @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  bookings FacilityBooking[]

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@map("facilities")
}

model FacilityBooking {
  id           String   @id @default(uuid())
  facilityId   String   @map("facility_id")
  bookedBy     String   @map("booked_by")
  bookedByName String   @map("booked_by_name")
  purpose      String?
  date         DateTime @db.Date
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  status       String   @default("confirmed") // confirmed, cancelled
  createdAt    DateTime @default(now()) @map("created_at")

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@index([date])
