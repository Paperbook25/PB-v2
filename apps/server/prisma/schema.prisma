// ==================== Student Attendance Models ====================

model StudentDailyAttendance {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  date           DateTime @db.Date
  classId        String   @map("class_id")
  sectionId      String   @map("section_id")
  markedBy       String?  @map("marked_by")
  totalStudents  Int      @default(0) @map("total_students")
  presentCount   Int      @default(0) @map("present_count")
  absentCount    Int      @default(0) @map("absent_count")
  lateCount      Int      @default(0) @map("late_count")
  halfDayCount   Int      @default(0) @map("half_day_count")
  excusedCount   Int      @default(0) @map("excused_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  class   Class                     @relation(fields: [classId], references: [id])
  section Section                   @relation(fields: [sectionId], references: [id])
  records StudentAttendanceRecord[]

  @@unique([date, classId, sectionId])
  @@index([classId])
  @@index([sectionId])
  @@index([date])
  @@index([organizationId])
  @@map("student_daily_attendance")
}

model StudentAttendanceRecord {
  id                String           @id @default(uuid())
  organizationId    String?          @map("organization_id")
  dailyAttendanceId String           @map("daily_attendance_id")
  studentId         String           @map("student_id")
  status            AttendanceStatus
  remarks           String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  dailyAttendance StudentDailyAttendance @relation(fields: [dailyAttendanceId], references: [id], onDelete: Cascade)
  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([dailyAttendanceId, studentId])
  @@index([dailyAttendanceId])
  @@index([studentId])
  @@index([organizationId])
  @@map("student_attendance_records")
}

model PeriodDefinition {
  id             String     @id @default(uuid())
  organizationId String?    @map("organization_id")
  name           String
  periodNumber   Int        @map("period_number")
  startTime      String     @map("start_time") @db.VarChar(10)
  endTime        String     @map("end_time") @db.VarChar(10)
  type           PeriodType @default(period_class)
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  periodAttendance PeriodAttendance[]
  timetableEntries TimetableEntry[]

  @@unique([organizationId, periodNumber])
  @@index([organizationId])
  @@map("period_definitions")
}

model PeriodAttendance {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  date           DateTime @db.Date
  classId        String   @map("class_id")
  sectionId      String   @map("section_id")
  periodId       String   @map("period_id")
  subjectId      String?  @map("subject_id")
  teacherId      String?  @map("teacher_id")
  records        Json // Array<{ studentId, status, remarks }>
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  class   Class            @relation(fields: [classId], references: [id])
  section Section          @relation(fields: [sectionId], references: [id])
  period  PeriodDefinition @relation(fields: [periodId], references: [id])
  subject Subject?         @relation(fields: [subjectId], references: [id])

  @@unique([date, classId, sectionId, periodId])
  @@index([classId])
  @@index([sectionId])
  @@index([periodId])
  @@index([date])
  @@index([organizationId])
  @@map("period_attendance")
}

// ==================== Staff Attendance + Leave Models ====================

model StaffDailyAttendance {
  id             String                @id @default(uuid())
  organizationId String?               @map("organization_id")
  date           DateTime              @db.Date
  staffId        String                @map("staff_id")
  status         StaffAttendanceStatus
  checkInTime    String?               @map("check_in_time") @db.VarChar(10)
  checkOutTime   String?               @map("check_out_time") @db.VarChar(10)
  remarks        String?
  markedBy       String?               @map("marked_by")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([date, staffId])
  @@index([staffId])
  @@index([date])
  @@index([organizationId])
  @@map("staff_daily_attendance")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  staffId        String    @map("staff_id")
  type           LeaveType
  academicYearId String    @map("academic_year_id")
  total          Int       @default(0)
  used           Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([staffId, type, academicYearId])
  @@index([staffId])
  @@index([academicYearId])
  @@index([organizationId])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(uuid())
  organizationId String?     @map("organization_id")
  staffId        String      @map("staff_id")
  type           LeaveType
  startDate      DateTime    @map("start_date") @db.Date
  endDate        DateTime    @map("end_date") @db.Date
  days           Float
  reason         String?     @db.Text
  status         LeaveStatus @default(leave_pending)
  reviewedBy     String?     @map("reviewed_by")
  reviewRemarks  String?     @map("review_remarks") @db.Text
  reviewedAt     DateTime?   @map("reviewed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([organizationId])
  @@map("leave_requests")
}

// ==================== Attendance & Leave Policy Models ====================

enum AlertType {
  alert_below_threshold
  alert_consecutive_absences
  alert_exam_ineligible
}

enum AlertSeverity {
  alert_warning
  alert_critical
}

enum BlackoutAppliesTo {
  blackout_all_staff
  blackout_teachers_only
  blackout_non_teaching
}

model AttendancePolicy {
  id                        String   @id @default(uuid())
  organizationId            String   @unique @map("organization_id")
  minimumPercentage         Int      @default(75) @map("minimum_percentage")
  warningPercentage         Int      @default(85) @map("warning_percentage")
  consecutiveAbsenceDays    Int      @default(3) @map("consecutive_absence_days")
  examEligibilityPercentage Int      @default(80) @map("exam_eligibility_percentage")
  notifyParent              Boolean  @default(true) @map("notify_parent")
  notifyTeacher             Boolean  @default(true) @map("notify_teacher")
  notifyPrincipal           Boolean  @default(true) @map("notify_principal")
  enabled                   Boolean  @default(true)
  schoolStartTime           String?  @map("school_start_time") @db.VarChar(10)
  lateAfterMinutes          Int      @default(15) @map("late_after_minutes")
  halfDayAfterTime          String?  @map("half_day_after_time") @db.VarChar(10)
  lateDetectionEnabled      Boolean  @default(false) @map("late_detection_enabled")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("attendance_policies")
}

model AttendanceAlert {
  id                String        @id @default(uuid())
  organizationId    String?       @map("organization_id")
  studentId         String        @map("student_id")
  type              AlertType
  severity          AlertSeverity
  currentPercentage Float?        @map("current_percentage")
  threshold         Float?
  message           String?       @db.Text
  acknowledgedAt    DateTime?     @map("acknowledged_at")
  acknowledgedBy    String?       @map("acknowledged_by")
  createdAt         DateTime      @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([organizationId])
  @@index([type])
  @@index([acknowledgedAt])
  @@map("attendance_alerts")
}

model StaffLeavePolicy {
  id                      String   @id @default(uuid())
  organizationId          String   @unique @map("organization_id")
  defaultEL               Int      @default(15) @map("default_el")
  defaultCL               Int      @default(12) @map("default_cl")
  defaultSL               Int      @default(12) @map("default_sl")
  defaultPL               Int      @default(7) @map("default_pl")
  maxCarryForwardDays     Int      @default(5) @map("max_carry_forward_days")
  carryForwardExpiryMonths Int     @default(3) @map("carry_forward_expiry_months")
  minNoticeDays           Int      @default(1) @map("min_notice_days")
  maxConsecutiveDays      Int      @default(15) @map("max_consecutive_days")
  sandwichLeaveEnabled    Boolean  @default(false) @map("sandwich_leave_enabled")
  probationLeaveFactor    Float    @default(0.5) @map("probation_leave_factor")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("staff_leave_policies")
}

model BlackoutDate {
  id             String            @id @default(uuid())
  organizationId String?           @map("organization_id")
  startDate      DateTime          @map("start_date") @db.Date
  endDate        DateTime          @map("end_date") @db.Date
  reason         String
  appliesTo      BlackoutAppliesTo @default(blackout_all_staff) @map("applies_to")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([startDate, endDate])
  @@map("blackout_dates")
}

model CustomLeaveType {
  id               String   @id @default(uuid())
  organizationId   String?  @map("organization_id")
  name             String
  code             String
  isPaid           Boolean  @default(true) @map("is_paid")
  maxDaysPerYear   Int      @default(10) @map("max_days_per_year")
  requiresApproval Boolean  @default(true) @map("requires_approval")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("custom_leave_types")
}

// ==================== Timetable Models ====================

model Room {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  name           String
  type           RoomType @default(room_classroom)
  capacity       Int?
  building       String?
  floor          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  timetableEntries TimetableEntry[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("rooms")
}

model Timetable {
  id             String          @id @default(uuid())
  organizationId String?         @map("organization_id")
  classId        String          @map("class_id")
  sectionId      String          @map("section_id")
  academicYearId String          @map("academic_year_id")
  effectiveFrom  DateTime?       @map("effective_from") @db.Date
  status         TimetableStatus @default(tt_draft)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  class        Class            @relation(fields: [classId], references: [id])
  section      Section          @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id])
  entries      TimetableEntry[]

  @@unique([classId, sectionId, academicYearId])
  @@index([classId])
  @@index([sectionId])
  @@index([academicYearId])
  @@index([status])
  @@index([organizationId])
  @@map("timetables")
}

model TimetableEntry {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  timetableId    String    @map("timetable_id")
  dayOfWeek      DayOfWeek @map("day_of_week")
  periodId       String    @map("period_id")
  subjectId      String?   @map("subject_id")
  teacherId      String?   @map("teacher_id")
  roomId         String?   @map("room_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  timetable     Timetable        @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  period        PeriodDefinition @relation(fields: [periodId], references: [id])
  subject       Subject?         @relation(fields: [subjectId], references: [id])
  room          Room?            @relation(fields: [roomId], references: [id])
  teacher       Staff?           @relation("EntryTeacher", fields: [teacherId], references: [id])
  substitutions Substitution[]

  @@unique([timetableId, dayOfWeek, periodId])
  @@index([timetableId])
  @@index([periodId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([roomId])
  @@index([organizationId])
  @@map("timetable_entries")
}

model Substitution {
  id                  String             @id @default(uuid())
  organizationId      String?            @map("organization_id")
  date                DateTime           @db.Date
  timetableEntryId    String             @map("timetable_entry_id")
  originalTeacherId   String?            @map("original_teacher_id")
  substituteTeacherId String?            @map("substitute_teacher_id")
  reason              String?
  status              SubstitutionStatus @default(sub_pending)
  approvedBy          String?            @map("approved_by")
  approvedAt          DateTime?          @map("approved_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  timetableEntry    TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  originalTeacher   Staff?         @relation("OriginalTeacher", fields: [originalTeacherId], references: [id])
  substituteTeacher Staff?         @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id])

  @@index([timetableEntryId])
  @@index([date])
  @@index([status])
  @@index([originalTeacherId])
  @@index([substituteTeacherId])
  @@index([organizationId])
  @@map("substitutions")
}

// ============================================================================
// Phase 5: Finance / Fees
// ============================================================================

enum FeeCategory {
  fee_tuition
  fee_development
  fee_lab
  fee_library
  fee_sports
  fee_computer
  fee_transport
  fee_examination
  fee_other
}

enum FeeFrequency {
  freq_monthly
  freq_quarterly
  freq_half_yearly
  freq_annual
  freq_one_time
}

enum FeePaymentStatus {
  fps_pending
  fps_partial
  fps_paid
  fps_overdue
  fps_waived
}

enum PaymentMode {
  pm_cash
  pm_upi
  pm_bank_transfer
  pm_cheque
  pm_dd
  pm_online
}

enum ExpenseCategory {
  exp_salary
  exp_utilities
  exp_maintenance
  exp_supplies
  exp_infrastructure
  exp_events
  exp_other
}

enum ExpenseStatus {
  es_pending_approval
  es_approved
  es_rejected
  es_paid
}

enum LedgerEntryType {
  ledger_credit
  ledger_debit
}

// ==================== Fee Type ====================

model FeeType {
  id             String      @id @default(uuid())
  organizationId String?     @map("organization_id")
  name           String
  category       FeeCategory
  description    String?     @db.Text
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  feeStructures FeeStructure[]

  @@unique([organizationId, name, category])
  @@index([organizationId])
  @@index([category])
  @@index([isActive])
  @@map("fee_types")
}

// ==================== Fee Structure ====================

model FeeStructure {
  id                String       @id @default(uuid())
  organizationId    String?      @map("organization_id")
  feeTypeId         String       @map("fee_type_id")
  academicYear      String       @map("academic_year")
  applicableClasses Json         @map("applicable_classes") // JSON string array
  amount            Decimal      @db.Decimal(12, 2)
  frequency         FeeFrequency
  dueDay            Int          @default(10) @map("due_day")
  isOptional        Boolean      @default(false) @map("is_optional")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  feeType     FeeType      @relation(fields: [feeTypeId], references: [id])
  studentFees StudentFee[]

  @@index([organizationId])
  @@index([feeTypeId])
  @@index([academicYear])
  @@index([isActive])
  @@map("fee_structures")
}

// ==================== Student Fee ====================

model StudentFee {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  studentId      String           @map("student_id")
  feeStructureId String           @map("fee_structure_id")
  feeTypeId      String           @map("fee_type_id")
  academicYear   String           @map("academic_year")
  totalAmount    Decimal          @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal          @default(0) @map("paid_amount") @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @map("discount_amount") @db.Decimal(12, 2)
  dueDate        DateTime         @map("due_date") @db.Date
  status         FeePaymentStatus @default(fps_pending)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments     Payment[]

  @@index([organizationId])
  @@index([studentId])
  @@index([feeStructureId])
  @@index([status])
  @@index([dueDate])
  @@index([academicYear])
  @@map("student_fees")
}

// ==================== Payment ====================

model Payment {
  id             String      @id @default(uuid())
  organizationId String?     @map("organization_id")
  receiptNumber  String      @unique @map("receipt_number")
  studentId      String      @map("student_id")
  studentFeeId   String      @map("student_fee_id")
  amount         Decimal     @db.Decimal(12, 2)
  paymentMode    PaymentMode @map("payment_mode")
  transactionRef String?     @map("transaction_ref")
  remarks        String?     @db.Text
  collectedBy    String?     @map("collected_by")
  collectedById  String?     @map("collected_by_id")
  collectedAt    DateTime    @default(now()) @map("collected_at")
  status         String      @default("active") // active | cancelled
  cancelledAt    DateTime?   @map("cancelled_at")
  cancelledBy    String?     @map("cancelled_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentFee StudentFee @relation(fields: [studentFeeId], references: [id])

  @@index([organizationId])
  @@index([studentId])
  @@index([studentFeeId])
  @@index([receiptNumber])
  @@index([collectedAt])
  @@index([status])
  @@map("payments")
}

// ==================== Expense ====================

model Expense {
  id             String          @id @default(uuid())
  organizationId String?         @map("organization_id")
  expenseNumber  String          @unique @map("expense_number")
  category       ExpenseCategory
  description    String          @db.Text
  amount         Decimal         @db.Decimal(12, 2)
  vendorName     String?         @map("vendor_name")
  invoiceNumber  String?         @map("invoice_number")
  invoiceDate    DateTime?       @map("invoice_date") @db.Date
  status         ExpenseStatus   @default(es_pending_approval)
  requestedBy    String?         @map("requested_by")
  requestedAt    DateTime        @default(now()) @map("requested_at")
  approvedBy     String?         @map("approved_by")
  approvedAt     DateTime?       @map("approved_at")
  rejectedBy     String?         @map("rejected_by")
  rejectedAt     DateTime?       @map("rejected_at")
  rejectedReason String?         @map("rejected_reason") @db.Text
  paidAt         DateTime?       @map("paid_at")
  paidBy         String?         @map("paid_by")
  paidRef        String?         @map("paid_ref")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@index([requestedAt])
  @@map("expenses")
}

// ==================== Ledger Entry ====================

model LedgerEntry {
  id              String          @id @default(uuid())
  organizationId  String?         @map("organization_id")
  date            DateTime        @db.Date
  type            LedgerEntryType
  category        String
  referenceId     String?         @map("reference_id")
  referenceNumber String?         @map("reference_number")
  description     String          @db.Text
  amount          Decimal         @db.Decimal(12, 2)
  balance         Decimal         @db.Decimal(14, 2)
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([date])
  @@index([type])
  @@index([category])
  @@index([referenceId])
  @@map("ledger_entries")
}

