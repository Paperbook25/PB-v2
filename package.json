{
  "name": "paperbook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:school": "turbo dev --filter=@paperbook/school",
    "dev:admin": "turbo dev --filter=@paperbook/admin",
    "dev:server": "turbo dev --filter=@paperbook/server",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @paperbook/server db:migrate",
    "db:seed": "pnpm --filter @paperbook/server db:seed",
    "db:generate": "pnpm --filter @paperbook/server db:generate",
    "db:studio": "pnpm --filter @paperbook/server db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@esbuild/linux-x64",
      "@esbuild/linux-arm64",
      "@esbuild/darwin-x64",
      "@esbuild/darwin-arm64",
      "@esbuild/win32-x64",
      "better-sqlite3",
      "msw",
      "sharp"
    ]
  }
}
