# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/paperbook"

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# AI / LLM — Local AI via Ollama (default)
LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:14b"

# Optional: cloud LLM providers (leave empty to use Ollama)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
