generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Phase 1: Auth + Users
// ============================================================================

enum Role {
  admin
  principal
  teacher
  accountant
  librarian
  transport_manager
  student
  parent
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          Role
  phone         String?
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Student-specific fields
  studentId     String?  @map("student_id")
  class         String?
  section       String?
  rollNumber    Int?     @map("roll_number")

  // Parent-specific fields
  childIds      String?  @map("child_ids") // JSON array stored as string

  sessions       Session[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]
  taughtSections Section[]     @relation("SectionClassTeacher")
  staff          Staff?

  @@index([role])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token") @db.VarChar(500)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  userName    String   @map("user_name")
  userRole    String   @map("user_role")
  action      String   // create, update, delete, login, logout, export, import, status_change
  module      String   // students, staff, admissions, attendance, finance, library, exams, transport, settings, auth
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  entityName  String   @default("") @map("entity_name")
  description String   @db.Text
  changes     Json? // JSON array of { field, oldValue, newValue }
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================================================
// Phase 2: School Settings + Academic Structure
// ============================================================================

enum AffiliationBoard {
  CBSE
  ICSE
  State
  IB
  Other
}

enum AcademicYearStatus {
  active
  completed
  upcoming
}

enum CalendarEventType {
  holiday
  exam
  ptm
  sports
  cultural
  workshop
  vacation
  other
}

enum TemplateCategory {
  fee
  attendance
  exam
  admission
  general
  transport
}

model SchoolProfile {
  id                String           @id @default(uuid())
  name              String
  address           String
  city              String
  state             String
  pincode           String           @db.VarChar(10)
  phone             String
  email             String
  website           String?
  logo              String?          @db.Text
  principalName     String           @map("principal_name")
  establishedYear   Int              @map("established_year")
  affiliationNumber String?          @map("affiliation_number")
  affiliationBoard  AffiliationBoard? @map("affiliation_board")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("school_profiles")
}

model AcademicYear {
  id        String             @id @default(uuid())
  name      String             // e.g. "2024-25"
  startDate DateTime           @map("start_date") @db.Date
  endDate   DateTime           @map("end_date") @db.Date
  isCurrent Boolean            @default(false) @map("is_current")
  status    AcademicYearStatus @default(upcoming)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  classSubjects ClassSubject[]
  leaveBalances LeaveBalance[]
  timetables    Timetable[]

  @@index([isCurrent])
  @@index([status])
  @@map("academic_years")
}

model Class {
  id        String   @id @default(uuid())
  name      String   // e.g. "Class 1"
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sections      Section[]
  classSubjects ClassSubject[]
  students      Student[]
  dailyAttendance   StudentDailyAttendance[]
  periodAttendance  PeriodAttendance[]
  timetables        Timetable[]

  @@index([sortOrder])
  @@map("classes")
}

model Section {
  id             String   @id @default(uuid())
  name           String   // e.g. "A", "B"
  classId        String   @map("class_id")
  classTeacherId String?  @map("class_teacher_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  class        Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher User? @relation("SectionClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students     Student[]
  dailyAttendance   StudentDailyAttendance[]
  periodAttendance  PeriodAttendance[]
  timetables        Timetable[]

  @@unique([classId, name])
  @@index([classId])
  @@index([classTeacherId])
  @@map("sections")
}

model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  type         String   @default("theory") // theory, practical, both
  maxMarks     Int      @default(100) @map("max_marks")
  passingMarks Int      @default(33) @map("passing_marks")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  classSubjects    ClassSubject[]
  periodAttendance PeriodAttendance[]
  timetableEntries TimetableEntry[]

  @@index([code])
  @@map("subjects")
}

model ClassSubject {
  id             String   @id @default(uuid())
  classId        String   @map("class_id")
  subjectId      String   @map("subject_id")
  academicYearId String   @map("academic_year_id")
  createdAt      DateTime @default(now()) @map("created_at")

  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId, academicYearId])
  @@index([classId])
  @@index([subjectId])
  @@index([academicYearId])
  @@map("class_subjects")
}

model CalendarEvent {
  id               String            @id @default(uuid())
  title            String
  description      String            @default("") @db.VarChar(2000)
  type             CalendarEventType
  startDate        DateTime          @map("start_date") @db.Date
  endDate          DateTime          @map("end_date") @db.Date
  isRecurring      Boolean           @default(false) @map("is_recurring")
  appliesToClasses Json?             @map("applies_to_classes") // JSON string array
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([type])
  @@index([startDate, endDate])
  @@map("calendar_events")
}

model EmailTemplate {
  id           String           @id @default(uuid())
  name         String
  subject      String
  body         String           @db.Text
  category     TemplateCategory
  variables    Json             // JSON string array of variable names
  isActive     Boolean          @default(true) @map("is_active")
  lastModified DateTime         @default(now()) @map("last_modified")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("email_templates")
}

model NotificationPreference {
  id                    String  @id @default(uuid())
  emailNotifications    Boolean @default(true) @map("email_notifications")
  smsNotifications      Boolean @default(true) @map("sms_notifications")
  feeReminders          Boolean @default(true) @map("fee_reminders")
  attendanceAlerts      Boolean @default(true) @map("attendance_alerts")
  examResults           Boolean @default(true) @map("exam_results")
  generalAnnouncements  Boolean @default(true) @map("general_announcements")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model BackupConfig {
  id                  String   @id @default(uuid())
  autoBackup          Boolean  @default(true) @map("auto_backup")
  backupFrequency     String   @default("daily") @map("backup_frequency") // daily, weekly, monthly
  lastBackupAt        DateTime? @map("last_backup_at")
  backupRetentionDays Int      @default(30) @map("backup_retention_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("backup_configs")
}

model ThemeConfig {
  id           String   @id @default(uuid())
  mode         String   @default("system") // light, dark, system
  primaryColor String   @default("#6d28d9") @map("primary_color")
  accentColor  String   @default("#7c3aed") @map("accent_color")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("theme_configs")
}

// ============================================================================
// Phase 3: Students + Staff
// ============================================================================

enum Gender {
  male
  female
  other
}

enum StudentStatus {
  active
  inactive
  graduated
  transferred
}

enum StaffStatus {
  active
  on_leave
  resigned
}

enum DocumentType {
  birth_certificate
  aadhar_card
  transfer_certificate
  photo
  address_proof
  marksheet
  medical_certificate
  caste_certificate
  income_certificate
  other
}

enum TimelineEventType {
  fee_paid
  attendance_marked
  book_issued
  book_returned
  marks_entered
  leave_applied
  document_uploaded
  profile_updated
  admission
  promotion
  transfer
}

enum SkillCategory {
  academic
  sports
  arts
  leadership
  technical
  communication
  other
}

enum PortfolioItemType {
  project
  achievement
  certificate
  publication
  competition
  other
}

enum PortfolioVisibility {
  public
  school
  private
}

enum PDType {
  certification
  workshop
  seminar
  training
  conference
  course
}

enum PDStatus {
  upcoming
  in_progress
  completed
  expired
}

enum ReviewPeriod {
  Q1
  Q2
  Q3
  Q4
  annual
}

enum ReviewStatus {
  draft
  submitted
  acknowledged
}

enum StaffSkillCategory {
  technical
  soft
  domain
  tool
  language
}

enum SkillProficiency {
  beginner
  intermediate
  advanced
  expert
}

enum CertificationCategory {
  teaching
  technical
  safety
  compliance
  professional
  other_cert
}

enum CertificationStatus {
  active_cert
  expired_cert
  revoked
}

enum OnboardingStatus {
  not_started
  onboarding_in_progress
  onboarding_completed
  on_hold
}

enum SeparationType {
  resignation
  termination
  retirement
  contract_end
  layoff
  death
}

enum ExitInterviewStatus {
  scheduled
  exit_completed
  cancelled
}

enum HandoverStatus {
  handover_not_started
  handover_in_progress
  handover_completed
}

enum FnFStatus {
  fnf_pending
  fnf_processed
  fnf_paid
}

// ==================== Student Models ====================

model Student {
  id              String        @id @default(uuid())
  admissionNumber String        @unique @map("admission_number")
  firstName       String        @map("first_name")
  lastName        String        @map("last_name")
  email           String        @unique
  phone           String?
  dateOfBirth     DateTime?     @map("date_of_birth") @db.Date
  gender          Gender?
  bloodGroup      String?       @map("blood_group")
  classId         String        @map("class_id")
  sectionId       String        @map("section_id")
  rollNumber      Int?          @map("roll_number")
  admissionDate   DateTime?     @map("admission_date") @db.Date
  photoUrl        String?       @map("photo_url")
  status          StudentStatus @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  class           Class    @relation(fields: [classId], references: [id])
  section         Section  @relation(fields: [sectionId], references: [id])
  address         StudentAddress?
  parent          StudentParent?
  healthRecord    StudentHealthRecord?
  documents       StudentDocument[]
  timelineEvents  StudentTimelineEvent[]
  skills          StudentSkill[]
  portfolioItems  StudentPortfolioItem[]
  siblingsOf      StudentSibling[] @relation("SiblingStudent")
  siblingsWith    StudentSibling[] @relation("SiblingOfStudent")
  attendanceRecords StudentAttendanceRecord[]
  studentFees     StudentFee[]
  feePayments     Payment[]

  @@index([classId])
  @@index([sectionId])
  @@index([status])
  @@index([admissionNumber])
  @@map("students")
}

model StudentAddress {
  id        String   @id @default(uuid())
  studentId String   @unique @map("student_id")
  street    String?
  city      String?
  state     String?
  pincode   String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_addresses")
}

model StudentParent {
  id            String   @id @default(uuid())
  studentId     String   @unique @map("student_id")
  fatherName    String?  @map("father_name")
  motherName    String?  @map("mother_name")
  guardianPhone String?  @map("guardian_phone")
  guardianEmail String?  @map("guardian_email")
  occupation    String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_parents")
}

model StudentHealthRecord {
  id                String   @id @default(uuid())
  studentId         String   @unique @map("student_id")
  allergies         Json?
  medicalConditions Json?    @map("medical_conditions")
  medications       Json?
  emergencyContact  Json?    @map("emergency_contact")
  bloodGroup        String?  @map("blood_group")
  height            Float?
  weight            Float?
  visionLeft        String?  @map("vision_left")
  visionRight       String?  @map("vision_right")
  lastCheckupDate   DateTime? @map("last_checkup_date") @db.Date
  insuranceProvider String?  @map("insurance_provider")
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_health_records")
}

model StudentDocument {
  id         String       @id @default(uuid())
  studentId  String       @map("student_id")
  type       DocumentType
  name       String
  fileName   String       @map("file_name")
  fileSize   Int?         @map("file_size")
  mimeType   String?      @map("mime_type")
  url        String
  uploadedBy String?      @map("uploaded_by")
  verified   Boolean      @default(false)
  verifiedBy String?      @map("verified_by")
  verifiedAt DateTime?    @map("verified_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@map("student_documents")
}

model StudentTimelineEvent {
  id          String            @id @default(uuid())
  studentId   String            @map("student_id")
  type        TimelineEventType
  title       String
  description String?           @db.Text
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([createdAt])
  @@map("student_timeline_events")
}

model StudentSibling {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  siblingId String   @map("sibling_id")
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation("SiblingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  sibling Student @relation("SiblingOfStudent", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([studentId])
  @@index([siblingId])
  @@map("student_siblings")
}

model StudentSkill {
  id               String        @id @default(uuid())
  studentId        String        @map("student_id")
  name             String
  category         SkillCategory
  proficiencyLevel Int           @default(1) @map("proficiency_level") // 1-5
  certifications   Json?
  endorsedBy       Json?         @map("endorsed_by")
  acquiredDate     DateTime?     @map("acquired_date") @db.Date
  notes            String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([category])
  @@map("student_skills")
}

model StudentPortfolioItem {
  id          String              @id @default(uuid())
  studentId   String              @map("student_id")
  title       String
  type        PortfolioItemType
  description String?             @db.Text
  date        DateTime?           @db.Date
  attachments Json?
  tags        Json?
  visibility  PortfolioVisibility @default(school)
  featured    Boolean             @default(false)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@map("student_portfolio_items")
}

// ==================== Staff Models ====================

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  headStaffId String?  @map("head_staff_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff   Staff[]
  head    Staff?  @relation("DepartmentHead", fields: [headStaffId], references: [id], onDelete: SetNull)

  @@index([headStaffId])
  @@map("departments")
}

model Designation {
  id        String   @id @default(uuid())
  name      String   @unique
  level     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  staff Staff[]

  @@map("designations")
}

model Staff {
  id              String      @id @default(uuid())
  employeeId      String      @unique @map("employee_id")
  userId          String?     @unique @map("user_id")
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  email           String      @unique
  phone           String?
  dateOfBirth     DateTime?   @map("date_of_birth") @db.Date
  gender          Gender?
  departmentId    String      @map("department_id")
  designationId   String      @map("designation_id")
  joiningDate     DateTime?   @map("joining_date") @db.Date
  photoUrl        String?     @map("photo_url")
  specialization  String?
  salary          Float?
  status          StaffStatus @default(active)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user                   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  department             Department   @relation(fields: [departmentId], references: [id])
  designation            Designation  @relation(fields: [designationId], references: [id])
  headOfDepartments      Department[] @relation("DepartmentHead")
  address                StaffAddress?
  qualifications         StaffQualification[]
  bankDetails            StaffBankDetails?
  professionalDevelopment StaffProfessionalDevelopment[]
  reviewsReceived        StaffPerformanceReview[] @relation("ReviewedStaff")
  reviewsGiven           StaffPerformanceReview[] @relation("ReviewerStaff")
  skillRecords           StaffSkillRecord[]
  certifications         StaffCertification[]
  onboardingChecklist    StaffOnboardingChecklist?
  exitInterview          StaffExitInterview?
  staffAttendance        StaffDailyAttendance[]
  leaveBalances          LeaveBalance[]
  leaveRequests          LeaveRequest[]
  timetableEntries       TimetableEntry[]  @relation("EntryTeacher")
  originalSubstitutions  Substitution[]    @relation("OriginalTeacher")
  substituteSubstitutions Substitution[]   @relation("SubstituteTeacher")

  @@index([departmentId])
  @@index([designationId])
  @@index([status])
  @@index([employeeId])
  @@map("staff")
}

model StaffAddress {
  id        String   @id @default(uuid())
  staffId   String   @unique @map("staff_id")
  street    String?
  city      String?
  state     String?
  pincode   String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_addresses")
}

model StaffQualification {
  id            String   @id @default(uuid())
  staffId       String   @map("staff_id")
  qualification String
  institution   String?
  year          Int?
  createdAt     DateTime @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@map("staff_qualifications")
}

model StaffBankDetails {
  id                String   @id @default(uuid())
  staffId           String   @unique @map("staff_id")
  bankName          String?  @map("bank_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountHolderName String?  @map("account_holder_name")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_bank_details")
}

model StaffProfessionalDevelopment {
  id             String    @id @default(uuid())
  staffId        String    @map("staff_id")
  type           PDType
  title          String
  provider       String?
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  status         PDStatus  @default(upcoming)
  certificateUrl String?   @map("certificate_url")
  hours          Float?
  cost           Float?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([status])
  @@map("staff_professional_development")
}

model StaffPerformanceReview {
  id                  String       @id @default(uuid())
  staffId             String       @map("staff_id")
  reviewerId          String       @map("reviewer_id")
  period              ReviewPeriod
  year                Int
  ratings             Json?
  overallRating       Float?       @map("overall_rating")
  strengths           String?      @db.Text
  areasOfImprovement  String?      @map("areas_of_improvement") @db.Text
  goals               String?      @db.Text
  status              ReviewStatus @default(draft)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  staff    Staff @relation("ReviewedStaff", fields: [staffId], references: [id], onDelete: Cascade)
  reviewer Staff @relation("ReviewerStaff", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([reviewerId])
  @@index([period, year])
  @@map("staff_performance_reviews")
}

model StaffSkillRecord {
  id               String             @id @default(uuid())
  staffId          String             @map("staff_id")
  skillName        String             @map("skill_name")
  category         StaffSkillCategory
  proficiency      SkillProficiency   @default(beginner)
  yearsOfExperience Float?            @map("years_of_experience")
  selfAssessed     Boolean            @default(true) @map("self_assessed")
  verifiedBy       String?            @map("verified_by")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([category])
  @@map("staff_skill_records")
}

model StaffCertification {
  id                  String                @id @default(uuid())
  staffId             String                @map("staff_id")
  name                String
  issuingOrganization String?               @map("issuing_organization")
  credentialId        String?               @map("credential_id")
  issueDate           DateTime?             @map("issue_date") @db.Date
  expiryDate          DateTime?             @map("expiry_date") @db.Date
  doesNotExpire       Boolean               @default(false) @map("does_not_expire")
  status              CertificationStatus   @default(active_cert)
  category            CertificationCategory @default(professional)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([expiryDate])
  @@index([status])
  @@map("staff_certifications")
}

model StaffOnboardingTask {
  id          String   @id @default(uuid())
  category    String
  name        String
  description String?  @db.Text
  assignedTo  String?  @map("assigned_to") // "hr", "manager", "it", etc.
  dueInDays   Int      @default(7) @map("due_in_days")
  isMandatory Boolean  @default(true) @map("is_mandatory")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("staff_onboarding_tasks")
}

model StaffOnboardingChecklist {
  id                   String           @id @default(uuid())
  staffId              String           @unique @map("staff_id")
  status               OnboardingStatus @default(not_started)
  assignedHR           String?          @map("assigned_hr")
  assignedManager      String?          @map("assigned_manager")
  tasks                Json?
  progress             Float            @default(0)
  startDate            DateTime?        @map("start_date") @db.Date
  targetCompletionDate DateTime?        @map("target_completion_date") @db.Date
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_onboarding_checklists")
}

model StaffExitInterview {
  id               String              @id @default(uuid())
  staffId          String              @unique @map("staff_id")
  lastWorkingDate  DateTime?           @map("last_working_date") @db.Date
  separationType   SeparationType?     @map("separation_type")
  interviewDate    DateTime?           @map("interview_date") @db.Date
  ratings          Json?
  reasonForLeaving Json?               @map("reason_for_leaving")
  handoverStatus   HandoverStatus      @default(handover_not_started) @map("handover_status")
  clearanceStatus  Json?               @map("clearance_status")
  fnfStatus        FnFStatus           @default(fnf_pending) @map("fnf_status")
  status           ExitInterviewStatus @default(scheduled)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_exit_interviews")
}

// ============================================================================
// Phase 4: Attendance + Timetable + Leave
// ============================================================================

enum AttendanceStatus {
  att_present
  att_absent
  att_late
  att_half_day
  att_excused
}

enum StaffAttendanceStatus {
  staff_present
  staff_absent
  staff_half_day
  staff_on_leave
}

enum LeaveType {
  EL
  CL
  SL
  PL
}

enum LeaveStatus {
  leave_pending
  leave_approved
  leave_rejected
  leave_cancelled
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum PeriodType {
  period_class
  period_break
  period_lunch
  period_assembly
  period_activity
}

enum TimetableStatus {
  tt_draft
  tt_published
  tt_archived
}

enum SubstitutionStatus {
  sub_pending
  sub_approved
  sub_rejected
  sub_completed
}

enum RoomType {
  room_classroom
  room_lab
  room_library
  room_auditorium
  room_sports
}

// ==================== Student Attendance Models ====================

model StudentDailyAttendance {
  id             String           @id @default(uuid())
  date           DateTime         @db.Date
  classId        String           @map("class_id")
  sectionId      String           @map("section_id")
  markedBy       String?          @map("marked_by")
  totalStudents  Int              @default(0) @map("total_students")
  presentCount   Int              @default(0) @map("present_count")
  absentCount    Int              @default(0) @map("absent_count")
  lateCount      Int              @default(0) @map("late_count")
  halfDayCount   Int              @default(0) @map("half_day_count")
  excusedCount   Int              @default(0) @map("excused_count")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  records StudentAttendanceRecord[]

  @@unique([date, classId, sectionId])
  @@index([classId])
  @@index([sectionId])
  @@index([date])
  @@map("student_daily_attendance")
}

model StudentAttendanceRecord {
  id                String           @id @default(uuid())
  dailyAttendanceId String           @map("daily_attendance_id")
  studentId         String           @map("student_id")
  status            AttendanceStatus
  remarks           String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  dailyAttendance StudentDailyAttendance @relation(fields: [dailyAttendanceId], references: [id], onDelete: Cascade)
  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([dailyAttendanceId, studentId])
  @@index([dailyAttendanceId])
  @@index([studentId])
  @@map("student_attendance_records")
}

model PeriodDefinition {
  id           String     @id @default(uuid())
  name         String
  periodNumber Int        @unique @map("period_number")
  startTime    String     @map("start_time") @db.VarChar(10)
  endTime      String     @map("end_time") @db.VarChar(10)
  type         PeriodType @default(period_class)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  periodAttendance PeriodAttendance[]
  timetableEntries TimetableEntry[]

  @@map("period_definitions")
}

model PeriodAttendance {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  classId   String   @map("class_id")
  sectionId String   @map("section_id")
  periodId  String   @map("period_id")
  subjectId String?  @map("subject_id")
  teacherId String?  @map("teacher_id")
  records   Json     // Array<{ studentId, status, remarks }>
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class   Class           @relation(fields: [classId], references: [id])
  section Section         @relation(fields: [sectionId], references: [id])
  period  PeriodDefinition @relation(fields: [periodId], references: [id])
  subject Subject?        @relation(fields: [subjectId], references: [id])

  @@unique([date, classId, sectionId, periodId])
  @@index([classId])
  @@index([sectionId])
  @@index([periodId])
  @@index([date])
  @@map("period_attendance")
}

// ==================== Staff Attendance + Leave Models ====================

model StaffDailyAttendance {
  id           String               @id @default(uuid())
  date         DateTime             @db.Date
  staffId      String               @map("staff_id")
  status       StaffAttendanceStatus
  checkInTime  String?              @map("check_in_time") @db.VarChar(10)
  checkOutTime String?              @map("check_out_time") @db.VarChar(10)
  remarks      String?
  markedBy     String?              @map("marked_by")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([date, staffId])
  @@index([staffId])
  @@index([date])
  @@map("staff_daily_attendance")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  staffId        String    @map("staff_id")
  type           LeaveType
  academicYearId String    @map("academic_year_id")
  total          Int       @default(0)
  used           Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([staffId, type, academicYearId])
  @@index([staffId])
  @@index([academicYearId])
  @@map("leave_balances")
}

model LeaveRequest {
  id            String      @id @default(uuid())
  staffId       String      @map("staff_id")
  type          LeaveType
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime    @map("end_date") @db.Date
  days          Float
  reason        String?     @db.Text
  status        LeaveStatus @default(leave_pending)
  reviewedBy    String?     @map("reviewed_by")
  reviewRemarks String?     @map("review_remarks") @db.Text
  reviewedAt    DateTime?   @map("reviewed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// ==================== Timetable Models ====================

model Room {
  id        String   @id @default(uuid())
  name      String   @unique
  type      RoomType @default(room_classroom)
  capacity  Int?
  building  String?
  floor     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  timetableEntries TimetableEntry[]

  @@map("rooms")
}

model Timetable {
  id             String          @id @default(uuid())
  classId        String          @map("class_id")
  sectionId      String          @map("section_id")
  academicYearId String          @map("academic_year_id")
  effectiveFrom  DateTime?       @map("effective_from") @db.Date
  status         TimetableStatus @default(tt_draft)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  class        Class        @relation(fields: [classId], references: [id])
  section      Section      @relation(fields: [sectionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  entries      TimetableEntry[]

  @@unique([classId, sectionId, academicYearId])
  @@index([classId])
  @@index([sectionId])
  @@index([academicYearId])
  @@index([status])
  @@map("timetables")
}

model TimetableEntry {
  id          String    @id @default(uuid())
  timetableId String    @map("timetable_id")
  dayOfWeek   DayOfWeek @map("day_of_week")
  periodId    String    @map("period_id")
  subjectId   String?   @map("subject_id")
  teacherId   String?   @map("teacher_id")
  roomId      String?   @map("room_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  timetable     Timetable       @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  period        PeriodDefinition @relation(fields: [periodId], references: [id])
  subject       Subject?        @relation(fields: [subjectId], references: [id])
  room          Room?           @relation(fields: [roomId], references: [id])
  teacher       Staff?          @relation("EntryTeacher", fields: [teacherId], references: [id])
  substitutions Substitution[]

  @@unique([timetableId, dayOfWeek, periodId])
  @@index([timetableId])
  @@index([periodId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([roomId])
  @@map("timetable_entries")
}

model Substitution {
  id                  String             @id @default(uuid())
  date                DateTime           @db.Date
  timetableEntryId    String             @map("timetable_entry_id")
  originalTeacherId   String?            @map("original_teacher_id")
  substituteTeacherId String?            @map("substitute_teacher_id")
  reason              String?
  status              SubstitutionStatus @default(sub_pending)
  approvedBy          String?            @map("approved_by")
  approvedAt          DateTime?          @map("approved_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  timetableEntry    TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  originalTeacher   Staff?         @relation("OriginalTeacher", fields: [originalTeacherId], references: [id])
  substituteTeacher Staff?         @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id])

  @@index([timetableEntryId])
  @@index([date])
  @@index([status])
  @@index([originalTeacherId])
  @@index([substituteTeacherId])
  @@map("substitutions")
}

// ============================================================================
// Phase 5: Finance / Fees
// ============================================================================

enum FeeCategory {
  fee_tuition
  fee_development
  fee_lab
  fee_library
  fee_sports
  fee_computer
  fee_transport
  fee_examination
  fee_other
}

enum FeeFrequency {
  freq_monthly
  freq_quarterly
  freq_half_yearly
  freq_annual
  freq_one_time
}

enum FeePaymentStatus {
  fps_pending
  fps_partial
  fps_paid
  fps_overdue
  fps_waived
}

enum PaymentMode {
  pm_cash
  pm_upi
  pm_bank_transfer
  pm_cheque
  pm_dd
  pm_online
}

enum ExpenseCategory {
  exp_salary
  exp_utilities
  exp_maintenance
  exp_supplies
  exp_infrastructure
  exp_events
  exp_other
}

enum ExpenseStatus {
  es_pending_approval
  es_approved
  es_rejected
  es_paid
}

enum LedgerEntryType {
  ledger_credit
  ledger_debit
}

// ==================== Fee Type ====================

model FeeType {
  id          String      @id @default(uuid())
  name        String
  category    FeeCategory
  description String?     @db.Text
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  feeStructures FeeStructure[]

  @@unique([name, category])
  @@index([category])
  @@index([isActive])
  @@map("fee_types")
}

// ==================== Fee Structure ====================

model FeeStructure {
  id                String       @id @default(uuid())
  feeTypeId         String       @map("fee_type_id")
  academicYear      String       @map("academic_year")
  applicableClasses Json         @map("applicable_classes") // JSON string array
  amount            Decimal      @db.Decimal(12, 2)
  frequency         FeeFrequency
  dueDay            Int          @default(10) @map("due_day")
  isOptional        Boolean      @default(false) @map("is_optional")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  feeType     FeeType      @relation(fields: [feeTypeId], references: [id])
  studentFees StudentFee[]

  @@index([feeTypeId])
  @@index([academicYear])
  @@index([isActive])
  @@map("fee_structures")
}

// ==================== Student Fee ====================

model StudentFee {
  id              String           @id @default(uuid())
  studentId       String           @map("student_id")
  feeStructureId  String           @map("fee_structure_id")
  feeTypeId       String           @map("fee_type_id")
  academicYear    String           @map("academic_year")
  totalAmount     Decimal          @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal          @default(0) @map("paid_amount") @db.Decimal(12, 2)
  discountAmount  Decimal          @default(0) @map("discount_amount") @db.Decimal(12, 2)
  dueDate         DateTime         @map("due_date") @db.Date
  status          FeePaymentStatus @default(fps_pending)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments     Payment[]

  @@index([studentId])
  @@index([feeStructureId])
  @@index([status])
  @@index([dueDate])
  @@index([academicYear])
  @@map("student_fees")
}

// ==================== Payment ====================

model Payment {
  id             String      @id @default(uuid())
  receiptNumber  String      @unique @map("receipt_number")
  studentId      String      @map("student_id")
  studentFeeId   String      @map("student_fee_id")
  amount         Decimal     @db.Decimal(12, 2)
  paymentMode    PaymentMode @map("payment_mode")
  transactionRef String?     @map("transaction_ref")
  remarks        String?     @db.Text
  collectedBy    String?     @map("collected_by")
  collectedById  String?     @map("collected_by_id")
  collectedAt    DateTime    @default(now()) @map("collected_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentFee StudentFee @relation(fields: [studentFeeId], references: [id])

  @@index([studentId])
  @@index([studentFeeId])
  @@index([receiptNumber])
  @@index([collectedAt])
  @@map("payments")
}

// ==================== Expense ====================

model Expense {
  id              String         @id @default(uuid())
  expenseNumber   String         @unique @map("expense_number")
  category        ExpenseCategory
  description     String         @db.Text
  amount          Decimal        @db.Decimal(12, 2)
  vendorName      String?        @map("vendor_name")
  invoiceNumber   String?        @map("invoice_number")
  invoiceDate     DateTime?      @map("invoice_date") @db.Date
  status          ExpenseStatus  @default(es_pending_approval)
  requestedBy     String?        @map("requested_by")
  requestedAt     DateTime       @default(now()) @map("requested_at")
  approvedBy      String?        @map("approved_by")
  approvedAt      DateTime?      @map("approved_at")
  rejectedBy      String?        @map("rejected_by")
  rejectedAt      DateTime?      @map("rejected_at")
  rejectedReason  String?        @map("rejected_reason") @db.Text
  paidAt          DateTime?      @map("paid_at")
  paidBy          String?        @map("paid_by")
  paidRef         String?        @map("paid_ref")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([category])
  @@index([status])
  @@index([requestedAt])
  @@map("expenses")
}

// ==================== Ledger Entry ====================

model LedgerEntry {
  id              String          @id @default(uuid())
  date            DateTime        @db.Date
  type            LedgerEntryType
  category        String
  referenceId     String?         @map("reference_id")
  referenceNumber String?         @map("reference_number")
  description     String          @db.Text
  amount          Decimal         @db.Decimal(12, 2)
  balance         Decimal         @db.Decimal(14, 2)
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([referenceId])
  @@map("ledger_entries")
}
